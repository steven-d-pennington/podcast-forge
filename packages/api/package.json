{
  "name": "@podcast-forge/api",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --import tsx src/server.ts",
    "import:legacy": "node --import tsx src/import/legacy-cli.ts",
    "test:config": "node --import tsx --test src/*.test.ts src/**/*.test.ts",
    "check": "tsc --noEmit && npm run test:config"
  },
  "dependencies": {
    "@podcast-forge/db": "file:../db",
    "ajv": "8.20.0",
    "fastify": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}
